page {
  background: #f3f6f4;
  color: #173735;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 28rpx;
}

.page-shell {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 28rpx 28rpx 48rpx;
}

.hero {
  background: linear-gradient(138deg, #103c3b 0%, #0f6b63 72%, #1b8176 100%);
  border-radius: 32rpx;
  box-shadow: 0 18rpx 44rpx rgba(16, 60, 59, 0.18);
  color: #ffffff;
  overflow: hidden;
  padding: 36rpx;
  position: relative;
}

.hero::after {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
  content: "";
  height: 260rpx;
  position: absolute;
  right: -92rpx;
  top: -98rpx;
  width: 260rpx;
}

.hero-kicker {
  color: #aee3d9;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.hero-title {
  font-size: 46rpx;
  font-weight: 800;
  line-height: 1.25;
  margin-top: 16rpx;
}

.hero-subtitle {
  color: rgba(255, 255, 255, 0.78);
  font-size: 25rpx;
  line-height: 1.65;
  margin-top: 14rpx;
  max-width: 540rpx;
}

.scope-badge {
  align-items: center;
  background: rgba(231, 168, 76, 0.18);
  border: 1rpx solid rgba(255, 213, 151, 0.46);
  border-radius: 999rpx;
  color: #ffe0aa;
  display: inline-flex;
  font-size: 22rpx;
  font-weight: 650;
  margin-top: 28rpx;
  padding: 10rpx 18rpx;
}

.section {
  margin-top: 34rpx;
}

.section-heading {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.section-title {
  color: #173735;
  font-size: 30rpx;
  font-weight: 800;
}

.section-note {
  color: #71827f;
  font-size: 22rpx;
}

.card {
  background: #ffffff;
  border: 1rpx solid #e6ece9;
  border-radius: 26rpx;
  box-shadow: 0 8rpx 26rpx rgba(30, 74, 70, 0.06);
  padding: 28rpx;
}

.form-card {
  margin-top: 24rpx;
}

.field {
  border-bottom: 1rpx solid #e9eeec;
  padding: 22rpx 0;
}

.field:last-child {
  border-bottom: 0;
}

.field-label {
  color: #667976;
  font-size: 23rpx;
  margin-bottom: 12rpx;
}

.field-value,
.field-input {
  color: #173735;
  font-size: 29rpx;
  min-height: 42rpx;
}

.field-input {
  box-sizing: border-box;
  width: 100%;
}

.inline-fields {
  display: flex;
  gap: 18rpx;
}

.inline-fields .field {
  flex: 1;
}

.check-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx 20rpx;
}

.check-item {
  color: #244946;
  font-size: 25rpx;
}

checkbox .wx-checkbox-input {
  border-color: #9cb5b1;
  border-radius: 7rpx;
  height: 32rpx;
  margin-right: 10rpx;
  width: 32rpx;
}

checkbox .wx-checkbox-input.wx-checkbox-input-checked {
  background: #0f6b63;
  border-color: #0f6b63;
}

.primary-button,
.secondary-button {
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 750;
  line-height: 88rpx;
  margin-top: 26rpx;
}

.primary-button {
  background: #0f6b63;
  color: #ffffff;
}

.primary-button[disabled] {
  background: #9bb4b0;
  color: rgba(255, 255, 255, 0.82);
}

.secondary-button {
  background: #e5f1ee;
  color: #0f6b63;
}

.text-button {
  color: #0f6b63;
  font-size: 24rpx;
  font-weight: 700;
}

.notice {
  background: #fff6e7;
  border: 1rpx solid #f5d8a9;
  border-radius: 20rpx;
  color: #795725;
  font-size: 24rpx;
  line-height: 1.6;
  margin-top: 22rpx;
  padding: 22rpx 24rpx;
}

.error-card {
  background: #fff1ef;
  border: 1rpx solid #f2c6bf;
  border-radius: 20rpx;
  color: #9a3f31;
  font-size: 24rpx;
  line-height: 1.6;
  margin-top: 22rpx;
  padding: 22rpx 24rpx;
}

.empty-state {
  color: #788885;
  padding: 70rpx 24rpx;
  text-align: center;
}

.loading-state {
  color: #71827f;
  padding: 50rpx 0;
  text-align: center;
}

.audit-strip {
  align-items: center;
  background: #edf5f3;
  border-radius: 18rpx;
  display: flex;
  justify-content: space-between;
  margin-top: 22rpx;
  padding: 20rpx 22rpx;
}

.audit-id {
  color: #496a66;
  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  font-size: 20rpx;
  max-width: 430rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-table {
  border: 1rpx solid #e4ebe8;
  border-radius: 18rpx;
  margin-top: 20rpx;
  overflow: hidden;
}

.table-row {
  border-bottom: 1rpx solid #edf1ef;
  display: flex;
  min-width: 620rpx;
}

.table-row:last-child {
  border-bottom: 0;
}

.table-row.header {
  background: #eaf3f1;
  color: #315b56;
  font-weight: 750;
}

.table-cell {
  box-sizing: border-box;
  flex: 1;
  font-size: 22rpx;
  line-height: 1.4;
  min-width: 150rpx;
  padding: 18rpx 14rpx;
  word-break: break-all;
}

.muted {
  color: #7d8e8b;
}

.mono {
  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
}
