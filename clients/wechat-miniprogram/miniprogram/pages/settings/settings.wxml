<view class="page-shell">
  <view class="hero settings-hero">
    <view class="hero-kicker">Environment</view>
    <view class="hero-title">连接测试环境</view>
    <view class="hero-subtitle">体验版默认直连阿里云固定 HTTPS 入口，CloudBase 仅作为备用链路。</view>
  </view>

  <view wx:if="{{error}}" class="error-card">{{error}}</view>
  <view wx:if="{{health}}" class="health-card">
    <view class="health-dot"></view>
    <view>
      <view class="health-title">{{assistantReady ? '服务与智能分析均正常' : '基础服务连接正常，智能分析未就绪'}}</view>
      <view class="health-note">{{health.environment}} · {{health.data_scope}} · v{{health.version}}</view>
      <view wx:if="{{health.assistant_proxy}}" class="health-note">智能分析代理：{{health.assistant_proxy.configured ? (health.assistant_proxy.reachable ? '已配置且可达' : '已配置但不可达') : '未配置'}}</view>
      <view wx:if="{{health.assistant_ready}}" class="health-note">会话：{{health.assistant_session_id}}</view>
      <view wx:if="{{health.assistant_ready}}" class="health-note">{{health.assistant_model}} · {{health.assistant_data_scope}}</view>
    </view>
  </view>

  <view class="card form-card">
    <view class="field mode-field">
      <view class="field-label">服务模式</view>
      <view class="mode-switch">
        <view class="mode-option {{transport === 'http' ? 'mode-option-active' : ''}}" bindtap="useHttp">阿里云固定入口</view>
        <view class="mode-option {{transport === 'cloudbase' ? 'mode-option-active' : ''}}" bindtap="useCloudbase">CloudBase 备用</view>
      </view>
    </view>

    <view wx:if="{{transport === 'cloudbase'}}" class="cloud-summary">
      <view class="cloud-title">CloudBase 备用云函数</view>
      <view class="cloud-value mono">{{cloudFunctionName}}</view>
      <view class="cloud-note mono">{{cloudEnvId}}</view>
    </view>

    <block wx:else>
      <view class="field">
        <view class="field-label">API 基础地址</view>
        <input class="field-input mono" value="{{apiBaseUrl}}" bindinput="onBaseUrlInput" placeholder="https://metro.9m-zx.com/assistant-bridge" />
      </view>
      <view class="field token-field">
        <view class="field-label">测试访问令牌（可选）</view>
        <view class="token-row">
          <input class="field-input mono" password="{{!showToken}}" value="{{accessToken}}" bindinput="onTokenInput" placeholder="由测试服务器管理员提供" />
          <view class="text-button token-toggle" bindtap="toggleToken">{{showToken ? '隐藏' : '显示'}}</view>
        </view>
      </view>
      <view class="local-hint">默认地址通过阿里云 ECS 和受限反向隧道调用本机 metroflow + gpt-5.6-sol。Mac 关机时不可用；重新开机登录后服务会自动恢复。</view>
    </block>
    <button class="primary-button" loading="{{testing}}" disabled="{{testing}}" bindtap="testConnection">测试并保存</button>
    <button class="secondary-button" bindtap="save">仅保存设置</button>
  </view>

  <view class="notice">
    <view class="notice-title">运行边界</view>
    <view>• 小程序只调用阿里云受控 HTTPS API，不直接连接数据库。</view>
    <view>• 不要在这里填写 AppSecret 或数据库密码。</view>
    <view>• 自然语言仍先编译为受约束 QueryIR，不执行模型自由 SQL。</view>
    <view>• CloudBase 备用模式保留用于故障对照，不再是默认主链路。</view>
  </view>

  <view class="reset-link" bindtap="clear">恢复阿里云默认地址</view>
</view>
