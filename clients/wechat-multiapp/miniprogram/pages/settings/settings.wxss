.settings-hero { padding-bottom: 32rpx; padding-top: 32rpx; }

.health-card {
  align-items: center;
  background: #eaf6f1;
  border: 1rpx solid #badfd2;
  border-radius: 22rpx;
  display: flex;
  margin-top: 22rpx;
  padding: 24rpx;
}

.health-dot {
  background: #26a276;
  border-radius: 50%;
  box-shadow: 0 0 0 10rpx rgba(38, 162, 118, 0.12);
  height: 20rpx;
  margin: 0 30rpx 0 10rpx;
  width: 20rpx;
}

.health-title { color: #176044; font-size: 26rpx; font-weight: 750; }
.health-note { color: #61867a; font-size: 21rpx; margin-top: 5rpx; }

.token-row { align-items: center; display: flex; }
.token-row .field-input { flex: 1; }
.token-toggle { margin-left: 18rpx; }
.notice-title { font-size: 25rpx; font-weight: 800; margin-bottom: 8rpx; }

.mode-field { margin-bottom: 24rpx; }

.mode-switch {
  background: #eef3f2;
  border-radius: 18rpx;
  display: flex;
  padding: 6rpx;
}

.mode-option {
  border-radius: 14rpx;
  color: #71817e;
  flex: 1;
  font-size: 24rpx;
  padding: 18rpx 8rpx;
  text-align: center;
}

.mode-option-active {
  background: #ffffff;
  box-shadow: 0 4rpx 14rpx rgba(31, 72, 65, 0.1);
  color: #176044;
  font-weight: 750;
}

.cloud-summary {
  background: #f0f8f5;
  border: 1rpx solid #c5e1d7;
  border-radius: 18rpx;
  margin-bottom: 24rpx;
  padding: 22rpx;
}

.cloud-title { color: #176044; font-size: 25rpx; font-weight: 750; }
.cloud-value { color: #2b5d51; font-size: 23rpx; margin-top: 10rpx; }
.cloud-note { color: #718b84; font-size: 19rpx; margin-top: 7rpx; word-break: break-all; }

.reset-link {
  color: #7c8f8b;
  font-size: 23rpx;
  margin-top: 34rpx;
  text-align: center;
  text-decoration: underline;
}
