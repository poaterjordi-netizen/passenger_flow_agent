{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/metro/query_ir.schema.json",
  "title": "Metro passenger-flow QueryIR",
  "type": "object",
  "additionalProperties": false,
  "required": ["metric", "time_range", "dimensions", "filters", "limit"],
  "properties": {
    "metric": {"type": "string", "minLength": 1},
    "time_range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {"type": "string", "format": "date-time"},
        "end": {"type": "string", "format": "date-time"}
      }
    },
    "dimensions": {
      "type": "array",
      "uniqueItems": true,
      "items": {"enum": ["line", "station", "direction", "time"]}
    },
    "filters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["field", "operator", "value"],
        "properties": {
          "field": {"enum": ["line_id", "station_id", "direction"]},
          "operator": {"enum": ["eq", "in"]},
          "value": {}
        }
      }
    },
    "limit": {"type": "integer", "minimum": 1, "maximum": 1000}
  }
}
