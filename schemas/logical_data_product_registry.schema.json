{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Logical data product registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "registry_version", "products"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "registry_version": {"type": "string", "minLength": 1},
    "products": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "logical_dataset", "dataset_role", "metric_ids", "dimensions", "time_basis",
          "timezone", "cross_midnight_policy", "quality_gate_id", "access_policy_id",
          "source_version_policy"
        ],
        "properties": {
          "logical_dataset": {"type": "string", "minLength": 1},
          "dataset_role": {"enum": ["actual", "reference", "forecast"]},
          "metric_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
          "dimensions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
          "time_basis": {"enum": ["event_time", "service_day"]},
          "timezone": {"const": "Asia/Shanghai"},
          "cross_midnight_policy": {"enum": ["reject", "service_day_calendar"]},
          "quality_gate_id": {"type": "string", "minLength": 1},
          "access_policy_id": {"type": "string", "minLength": 1},
          "source_version_policy": {"const": "immutable-only"}
        }
      }
    }
  }
}
