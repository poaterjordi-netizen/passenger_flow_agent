# Never place production credentials in this tracked example.
METRO_AGENT_ENV=development
METRO_AGENT_DATA_DIR=examples/synthetic_data
METRO_AGENT_LOG_LEVEL=INFO

# Governed mobile API. Synthetic remains the fail-closed default.
METRO_API_HOST=127.0.0.1
METRO_API_PORT=8000
METRO_API_METRICS_PATH=examples/synthetic_data/metrics.json
METRO_API_DATA_PATH=examples/synthetic_data/passenger_flow.csv
METRO_API_AUDIT_DIR=artifacts/api-audits
METRO_API_ACCESS_TOKEN=
METRO_API_CORS_ORIGINS=
METRO_API_DATA_MODE=synthetic

# Production-shadow metadata. Keep blocked/empty until business and data owners approve it.
METRO_PRODUCTION_SOURCE_STATUS=blocked
METRO_PRODUCTION_CITY=
METRO_PRODUCTION_SOURCE_VERSION=
METRO_PRODUCTION_TIME_GRAIN=
METRO_PRODUCTION_DEFAULT_START=
METRO_PRODUCTION_DEFAULT_END=
METRO_PRODUCTION_REGISTRY_PATH=
METRO_LOGICAL_REGISTRY_PATH=config/logical_data_products.json
METRO_PRODUCTION_ASSISTANT_ENABLED=false
METRO_LOCAL_LIVE_SHADOW_ACKNOWLEDGED=false
METRO_PROMOTION_GATE_PATH=config/production_promotion_gates.json

# Trusted identity scope for the static-token adapter. Required in production-shadow.
# A gateway/identity-provider adapter should replace this single-subject mapping in production.
METRO_ACCESS_SUBJECT_ID=
METRO_ACCESS_TENANT_OR_DEPARTMENT=
METRO_ACCESS_ROLES=
METRO_ACCESS_ALLOWED_CITIES=
METRO_ACCESS_ALLOWED_METRICS=
METRO_ACCESS_ALLOWED_DATASET_ROLES=
METRO_ACCESS_MAX_TIME_RANGE_HOURS=24
METRO_ACCESS_ROW_LIMIT=100
METRO_ACCESS_EXPORT_POLICY=deny
METRO_ACCESS_POLICY_SNAPSHOT_ID=

# Real Evidence remains inside the deterministic renderer unless explicitly approved.
METRO_MODEL_ENDPOINT_POLICY_ID=
METRO_MODEL_DATA_EGRESS=deny
METRO_MODEL_INTENT_EGRESS=deny
# Production approval binds all three values exactly. Obtain the runtime target hash from
# GET /api/v1/governance/status and place the approved value in deployment configuration.
METRO_MODEL_ALLOWED_PROVIDER=
METRO_MODEL_ALLOWED_MODEL=
METRO_MODEL_ALLOWED_TARGET_HASH=

# Governed assistant. Fake mode is offline and deterministic. Inject real keys at runtime only.
METRO_ASSISTANT_PROVIDER=fake
METRO_ASSISTANT_MODEL=gpt-5.6-sol
METRO_ASSISTANT_REASONING_EFFORT=medium
METRO_ASSISTANT_HERMES_COMMAND=hermes
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Runtime-only MySQL adapter. Leave secrets empty and inject them securely.
METRO_DB_HOST=
METRO_DB_PORT=3306
METRO_DB_USER=
METRO_DB_PASSWORD=
METRO_DB_NAME=
METRO_DB_CONNECT_TIMEOUT=8
METRO_DB_READ_TIMEOUT=30
METRO_DB_SSL_CA=
METRO_DB_TLS_CERT_SHA256=
METRO_DB_ALLOW_INSECURE_TLS=false
